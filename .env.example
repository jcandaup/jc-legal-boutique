# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_GOOGLE_SHEETS_WEBHOOK_URL: The URL of the Google Apps Script web app
VITE_GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/AKfycbzd9co2sqGe8ebs9FP4qbe7JPooswtA2Tn8bg8qeK0WjBVyGgIJdm0fYw-dvK6g1g/exec
